---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import ArticleCard from '../components/ArticleCard.astro';
import AboutSection from '../components/AboutSection.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import { client, urlFor } from '../lib/sanity';
import { getLabelSlug } from '../lib/categories';
import type { SanityImageSource } from '@sanity/image-url/lib/types/types';

interface RecentArticle {
  title: string;
  excerpt: string;
  category: string;
  slug: string;
  mainImage: SanityImageSource | null;
}

const recentArticles = await client.fetch<RecentArticle[]>(
  `*[_type == "article"] | order(publishedAt desc)[0..3] {
    title,
    excerpt,
    category,
    "slug": slug.current,
    mainImage
  }`
).catch(() => [] as RecentArticle[]);

const FEATURED_SLUGS = [
  'tecnicas-relajacion-dormirte-rapido',
  'alimentos-para-dormir-mejor',
  'insomnio-causas-soluciones-naturales',
];

interface FeaturedArticleRaw {
  title: string;
  excerpt: string;
  category: string;
  slug: string;
  mainImage: SanityImageSource | null;
}

const featuredRaw = await client.fetch<FeaturedArticleRaw[]>(
  `*[_type == "article" && slug.current in $slugs] {
    title,
    excerpt,
    category,
    "slug": slug.current,
    mainImage
  }`,
  { slugs: FEATURED_SLUGS }
).catch(() => [] as FeaturedArticleRaw[]);

const featuredArticles = FEATURED_SLUGS
  .map(slug => featuredRaw.find(a => a.slug === slug))
  .filter((a): a is FeaturedArticleRaw => a !== undefined)
  .map(a => ({
    title: a.title,
    excerpt: a.excerpt,
    category: a.category,
    categorySlug: getLabelSlug(a.category),
    slug: a.slug,
    imageUrl: a.mainImage ? urlFor(a.mainImage).width(640).height(360).url() : undefined,
  }));
---

<BaseLayout
  title="Sueño Profundo — Tu guía para dormir mejor"
  description="Técnicas, remedios naturales y ciencia del sueño — todo en español, para que descanses como mereces."
  canonicalUrl="https://simplesleep.mx"
>
  <Header />

  <main>
    <HeroSection featuredArticles={featuredArticles} />
    <CategoryGrid />

    <!-- Artículos Recientes -->
    <section class="recent-articles section" aria-labelledby="recent-heading">
      <div class="container">
        <div class="section-header recent-header">
          <div>
            <h2 class="section-title" id="recent-heading">Artículos Recientes</h2>
            <p class="section-subtitle">Lo último de nuestro equipo editorial.</p>
          </div>
          <a href="/articulos" class="view-all-link" aria-label="Ver todos los artículos recientes">
            Ver todos →
          </a>
        </div>
        <div class="recent-grid">
          {recentArticles.map(article => (
            <ArticleCard
              title={article.title}
              excerpt={article.excerpt}
              category={article.category}
              categorySlug={getLabelSlug(article.category)}
              slug={article.slug}
              imageUrl={article.mainImage ? urlFor(article.mainImage).width(640).height(360).url() : undefined}
            />
          ))}
        </div>
      </div>
    </section>

    <AboutSection />
    <NewsletterCTA />
  </main>

  <Footer />
</BaseLayout>

<style>
  .recent-articles {
    background-color: var(--color-bg);
  }

  .recent-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .view-all-link {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-primary);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color var(--transition-fast);
    padding-bottom: var(--space-1);
  }

  .view-all-link:hover {
    color: var(--color-secondary);
  }

  .recent-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .recent-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .recent-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .recent-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
