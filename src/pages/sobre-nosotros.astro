---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AboutSection from '../components/AboutSection.astro';
---

<BaseLayout
  title="Sobre Nosotros | Sueño Profundo"
  description="Conoce la misión de Sueño Profundo: llevar información científica y práctica sobre el sueño a todos los hispanohablantes."
>
  <Header />
  <main aria-label="Sobre Nosotros">
    <header class="page-header">
      <div class="container">
        <nav aria-label="Migas de pan" class="breadcrumb">
          <a href="/">Inicio</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">Sobre Nosotros</span>
        </nav>
        <h1 class="page-title">Sobre Nosotros</h1>
      </div>
    </header>
    <AboutSection />
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-10) 0 var(--space-6);
    background-color: var(--color-surface);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .breadcrumb a {
    color: var(--color-primary);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    margin: 0;
  }
</style>
