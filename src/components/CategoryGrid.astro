---
const categories = [
  {
    label: 'Técnicas para Dormir',
    slug: 'tecnicas-para-dormir',
    emoji: '🧘',
    color: '#E8F4FF',
    accentColor: '#2D3A8C',
  },
  {
    label: 'Higiene del Sueño',
    slug: 'higiene-del-sueno',
    emoji: '🛁',
    color: '#F0F9FF',
    accentColor: '#0284C7',
  },
  {
    label: 'Remedios Naturales',
    slug: 'remedios-naturales',
    emoji: '🌿',
    color: '#F0FDF4',
    accentColor: '#15803D',
  },
  {
    label: 'Trastornos del Sueño',
    slug: 'trastornos-del-sueno',
    emoji: '😴',
    color: '#FFF1F2',
    accentColor: '#BE185D',
  },
  {
    label: 'Ciencia del Sueño',
    slug: 'ciencia-del-sueno',
    emoji: '🔬',
    color: '#EFF6FF',
    accentColor: '#1D4ED8',
  },
  {
    label: 'Nutrición y Sueño',
    slug: 'nutricion-y-sueno',
    emoji: '🥗',
    color: '#FFFBEB',
    accentColor: '#92400E',
  },
  {
    label: 'Sueño por Etapa de Vida',
    slug: 'sueno-por-etapa',
    emoji: '👶',
    color: '#FDF4FF',
    accentColor: '#7E22CE',
  },
  {
    label: 'Situaciones Especiales',
    slug: 'situaciones-especiales',
    emoji: '✈️',
    color: '#F0FDFA',
    accentColor: '#0F766E',
  },
  {
    label: 'Productos para Dormir',
    slug: 'productos-para-dormir',
    emoji: '🛏️',
    color: '#FFF7ED',
    accentColor: '#C2410C',
  },
  {
    label: 'Estilo de Vida y Sueño',
    slug: 'estilo-de-vida',
    emoji: '🌅',
    color: '#FFF5F5',
    accentColor: '#B91C1C',
  },
];
---

<section class="categories section" aria-label="Explorar categorías">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Explora por Categoría</h2>
      <p class="section-subtitle">Encuentra exactamente lo que necesitas para mejorar tu sueño.</p>
    </div>

    <ul class="categories-grid" role="list">
      {categories.map(cat => (
        <li>
          <a
            href={`/categoria/${cat.slug}`}
            class="category-card"
            style={`--cat-bg: ${cat.color}; --cat-accent: ${cat.accentColor};`}
            aria-label={`Ver artículos de ${cat.label}`}
          >
            <div class="category-icon" aria-hidden="true">{cat.emoji}</div>
            <span class="category-label">{cat.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .categories {
    background-color: var(--color-bg-blue);
    padding: var(--space-20) 0;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-4);
  }

  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-3);
    padding: var(--space-6) var(--space-4);
    background-color: var(--cat-bg, #EFF6FF);
    border-radius: var(--radius-xl);
    border: 2px solid transparent;
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
    text-decoration: none;
  }

  .category-card:hover {
    transform: translateY(-4px);
    border-color: var(--cat-accent, var(--color-primary));
    box-shadow: var(--shadow-md);
  }

  .category-icon {
    font-size: 2rem;
    line-height: 1;
    display: block;
  }

  .category-label {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--cat-accent, var(--color-primary));
    line-height: 1.3;
  }

  @media (max-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 768px) {
    .categories-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
    }

    .category-card {
      padding: var(--space-4) var(--space-3);
    }

    .category-icon {
      font-size: 1.5rem;
    }

    .category-label {
      font-size: var(--text-xs);
    }
  }

  @media (max-width: 480px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
