---
const footerNav = [
  {
    heading: 'Categorías',
    links: [
      { label: 'Técnicas para Dormir', href: '/categoria/tecnicas-para-dormir' },
      { label: 'Higiene del Sueño', href: '/categoria/higiene-del-sueno' },
      { label: 'Remedios Naturales', href: '/categoria/remedios-naturales' },
      { label: 'Trastornos del Sueño', href: '/categoria/trastornos-del-sueno' },
      { label: 'Ciencia del Sueño', href: '/categoria/ciencia-del-sueno' },
    ],
  },
  {
    heading: 'Más Temas',
    links: [
      { label: 'Nutrición y Sueño', href: '/categoria/nutricion-y-sueno' },
      { label: 'Sueño por Etapa de Vida', href: '/categoria/sueno-por-etapa' },
      { label: 'Situaciones Especiales', href: '/categoria/situaciones-especiales' },
      { label: 'Productos para Dormir', href: '/categoria/productos-para-dormir' },
      { label: 'Estilo de Vida y Sueño', href: '/categoria/estilo-de-vida' },
    ],
  },
  {
    heading: 'Sitio',
    links: [
      { label: 'Acerca de Nosotros', href: '/acerca-de' },
      { label: 'Contacto', href: '/contacto' },
      { label: 'Política de Privacidad', href: '/privacidad' },
      { label: 'Términos de Uso', href: '/terminos' },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Sueño Profundo — Inicio">
          <span class="footer-logo-icon" aria-hidden="true">🌙</span>
          <span class="footer-logo-text">Sueño<strong>Profundo</strong></span>
        </a>
        <p class="footer-tagline">
          Tu guía en español para dormir mejor y vivir con más energía.
        </p>
        <!-- Social Icons -->
        <div class="social-links" aria-label="Redes sociales">
          <a href="#" class="social-link" aria-label="Síguenos en Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Síguenos en Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Síguenos en Pinterest">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.08 3.16 9.43 7.63 11.17-.1-.93-.2-2.36.04-3.37.22-.9 1.46-6.18 1.46-6.18s-.37-.75-.37-1.86c0-1.74 1.01-3.05 2.27-3.05 1.07 0 1.59.8 1.59 1.77 0 1.08-.69 2.69-1.04 4.18-.3 1.25.62 2.26 1.84 2.26 2.21 0 3.7-2.84 3.7-6.2 0-2.56-1.73-4.35-4.21-4.35-2.87 0-4.55 2.15-4.55 4.37 0 .87.33 1.79.75 2.3.08.1.09.19.07.29l-.28 1.14c-.04.18-.15.22-.33.13-1.25-.58-2.03-2.42-2.03-3.89 0-3.16 2.3-6.07 6.63-6.07 3.48 0 6.19 2.48 6.19 5.8 0 3.46-2.18 6.24-5.2 6.24-1.02 0-1.97-.53-2.3-1.15l-.62 2.33c-.23.86-.83 1.94-1.23 2.6.93.29 1.91.44 2.93.44 6.63 0 12-5.37 12-12S18.63 0 12 0z"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Síguenos en YouTube">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.97C18.88 4 12 4 12 4s-6.88 0-8.59.45a2.78 2.78 0 0 0-1.95 1.97A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 0 0 1.95-1.97A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
              <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav Columns -->
      {footerNav.map(col => (
        <div class="footer-col">
          <h3 class="footer-col-heading">{col.heading}</h3>
          <ul class="footer-col-list">
            {col.links.map(link => (
              <li>
                <a href={link.href} class="footer-link">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="copyright">
        © {currentYear} SuenoProfundo.com — Todos los derechos reservados.
      </p>
      <p class="disclaimer">
        El contenido de este sitio es informativo y no sustituye el consejo médico profesional.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-night);
    color: rgba(255, 255, 255, 0.75);
    padding: var(--space-16) 0 var(--space-8);
    margin-top: var(--space-20);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--space-10);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: var(--space-8);
  }

  /* Brand column */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    text-decoration: none;
  }

  .footer-logo-icon {
    font-size: 1.5rem;
  }

  .footer-logo-text {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--color-text-light);
  }

  .footer-logo-text strong {
    font-weight: 700;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: var(--space-6);
    max-width: 260px;
  }

  .social-links {
    display: flex;
    gap: var(--space-3);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    background-color: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.65);
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .social-link:hover {
    background-color: var(--color-secondary);
    color: var(--color-text-light);
  }

  /* Nav columns */
  .footer-col-heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-secondary);
    margin-bottom: var(--space-4);
  }

  .footer-col-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-link {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.65);
    transition: color var(--transition-fast);
    line-height: 1.5;
  }

  .footer-link:hover {
    color: var(--color-text-light);
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .copyright,
  .disclaimer {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.5;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-tagline {
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
